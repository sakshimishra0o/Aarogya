{
  "rules": {
    "users": {
      "patients": {
        ".read": "auth != null",
        "$uid": {
          ".read": "auth != null && (auth.uid == $uid || root.child('users/admin').child(auth.uid).exists() || root.child('users/doctors').child(auth.uid).exists())",
          ".write": "auth != null && (auth.uid == $uid || root.child('users/admin').child(auth.uid).exists())"
        }
      },
      "doctors": {
        ".read": "auth != null",
        "$uid": {
          ".read": "auth != null",
          ".write": "auth != null && (auth.uid == $uid || root.child('users/admin').child(auth.uid).exists())"
        }
      },
      "admin": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$uid": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    },
    "doctorStatus": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "sessions": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["patientId", "doctorId", "status"],
      "$sessionId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "chat": {
          ".read": "auth != null",
          ".write": "auth != null"
        },
        "healthData": {
          ".read": "auth != null",
          ".write": "auth != null && root.child('sessions').child($sessionId).child('patientId').val() == auth.uid"
        },
        "webrtc": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    }
  }
}