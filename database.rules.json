{
  "rules": {
    ".read": "auth != null && (auth.uid === 'oGTYVxmnH1Vsk0h4jee7lSUia183' || auth.token.email === 'AarogyaCloud@gmail.com' || root.child('users/admins').child(auth.uid).exists())",
    ".write": "auth != null && (auth.uid === 'oGTYVxmnH1Vsk0h4jee7lSUia183' || auth.token.email === 'AarogyaCloud@gmail.com' || root.child('users/admins').child(auth.uid).exists())",
    "users": {
      "admins": {
        ".read": "auth != null"
      },
      "admin": {
        ".read": "auth != null"
      },
      "doctors": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && auth.uid === $uid",
          "busy": {
            ".write": "auth != null"
          },
          "activeSessionId": {
            ".write": "auth != null"
          }
        }
      },
      "patients": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "sessions": {
      ".read": "auth != null",
      ".indexOn": ["patientId", "doctorId"],
      "$sessionId": {
        ".write": "auth != null"
      }
    },
    "doctorStatus": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}